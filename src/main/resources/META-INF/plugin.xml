<idea-plugin>
    <id>com.github.tdavtyan.riderworktrees</id>
    <name>Git Worktrees</name>
    <vendor>tdavtyan</vendor>

    <description><![CDATA[
        <h2>Git Worktree Manager for JetBrains IDEs</h2>
        <p>Manage multiple Git worktrees directly from your IDE without touching the command line.</p>

        <h3>Features</h3>
        <ul>
            <li><b>Worktree Tree View</b> — Collapsible tree showing all worktrees with their changed files and status indicators</li>
            <li><b>Inline Diff</b> — Double-click any changed file to see a side-by-side diff (HEAD vs Working Copy)</li>
            <li><b>Create / Remove / Open</b> — Full worktree lifecycle management from the tool window</li>
            <li><b>Lock / Unlock / Prune</b> — Protect worktrees from accidental deletion and clean up stale entries</li>
            <li><b>Window Title</b> — Shows the current branch/worktree name in the IDE title bar for easy identification</li>
            <li><b>Auto-detection</b> — Tool window appears automatically when your project has multiple worktrees</li>
            <li><b>Switch Worktrees</b> — Open any worktree in a new IDE window with a double-click</li>
        </ul>

        <h3>Getting Started</h3>
        <p>Open the <b>Git Worktrees</b> tool window from the bottom panel. Your existing worktrees will be listed automatically.
        Use the toolbar buttons to create new worktrees, or right-click for more actions.</p>
    ]]></description>

    <change-notes><![CDATA[
        <h3>0.1.3</h3>
        <ul>
            <li>Fixed deprecated API usage: replaced scheduled-for-removal addBrowseFolderListener overload</li>
            <li>Removed deprecated UiCompatibleDataProvider.getData override</li>
        </ul>
        <h3>0.1.2</h3>
        <ul>
            <li>Maintenance release</li>
        </ul>
        <h3>0.1.1</h3>
        <ul>
            <li>Fixed toolbar icons for Lock, Unlock, and Prune actions</li>
            <li>Distinct tree icons: home folder for main worktree, patch icon for worktrees with changes</li>
            <li>Fixed diff viewer running on UI thread (SlowOperations error)</li>
        </ul>
        <h3>0.1.0</h3>
        <ul>
            <li>Initial release</li>
            <li>Worktree tree view with file change status</li>
            <li>Inline diff viewer</li>
            <li>Create, open, remove, lock, unlock, and prune worktrees</li>
            <li>Window title shows current worktree branch</li>
            <li>Auto-show tool window for multi-worktree projects</li>
        </ul>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <projectService
            serviceInterface="com.github.tdavtyan.riderworktrees.services.WorktreeService"
            serviceImplementation="com.github.tdavtyan.riderworktrees.services.WorktreeServiceImpl"/>

        <toolWindow id="Git Worktrees"
                    anchor="bottom"
                    secondary="false"
                    icon="AllIcons.Actions.SplitVertically"
                    doNotActivateOnStart="true"
                    factoryClass="com.github.tdavtyan.riderworktrees.ui.WorktreeToolWindowFactory"/>

        <postStartupActivity
            implementation="com.github.tdavtyan.riderworktrees.services.WorktreeProjectActivity"/>

        <projectConfigurable
            instance="com.github.tdavtyan.riderworktrees.settings.WorktreeConfigurable"
            id="com.github.tdavtyan.riderworktrees.settings"
            parentId="project.propVCSSupport.Mappings"
            displayName="Git Worktrees"/>

        <notificationGroup id="GitWorktrees"
                           displayType="BALLOON"/>

        <frameTitleBuilder implementation="com.github.tdavtyan.riderworktrees.ui.WorktreeFrameTitleBuilder"
                           order="first"/>
    </extensions>

    <actions>
        <action id="RiderWorktrees.Create"
                class="com.github.tdavtyan.riderworktrees.actions.CreateWorktreeAction"
                text="Create Worktree..."
                description="Create a new git worktree"
                icon="AllIcons.General.Add"/>

        <action id="RiderWorktrees.Open"
                class="com.github.tdavtyan.riderworktrees.actions.OpenWorktreeAction"
                text="Open Worktree"
                description="Open worktree in a new IDE window"
                icon="AllIcons.Actions.OpenNewTab"/>

        <action id="RiderWorktrees.Remove"
                class="com.github.tdavtyan.riderworktrees.actions.RemoveWorktreeAction"
                text="Remove Worktree..."
                description="Remove the selected git worktree"
                icon="AllIcons.General.Remove"/>

        <action id="RiderWorktrees.Refresh"
                class="com.github.tdavtyan.riderworktrees.actions.RefreshWorktreesAction"
                text="Refresh Worktrees"
                description="Refresh the worktree list"
                icon="AllIcons.Actions.Refresh"/>

        <action id="RiderWorktrees.Lock"
                class="com.github.tdavtyan.riderworktrees.actions.LockWorktreeAction"
                text="Lock Worktree"
                description="Lock the selected worktree to prevent pruning"
                icon="AllIcons.Diff.Lock"/>

        <action id="RiderWorktrees.Unlock"
                class="com.github.tdavtyan.riderworktrees.actions.UnlockWorktreeAction"
                text="Unlock Worktree"
                description="Unlock the selected worktree"
                icon="AllIcons.Actions.Cancel"/>

        <action id="RiderWorktrees.Prune"
                class="com.github.tdavtyan.riderworktrees.actions.PruneWorktreesAction"
                text="Prune Stale Worktrees"
                description="Remove stale worktree entries"
                icon="AllIcons.Actions.ClearCash"/>

        <group id="RiderWorktrees.ToolWindowToolbar">
            <reference ref="RiderWorktrees.Create"/>
            <reference ref="RiderWorktrees.Remove"/>
            <reference ref="RiderWorktrees.Open"/>
            <separator/>
            <reference ref="RiderWorktrees.Lock"/>
            <reference ref="RiderWorktrees.Unlock"/>
            <separator/>
            <reference ref="RiderWorktrees.Prune"/>
            <reference ref="RiderWorktrees.Refresh"/>
        </group>

        <group id="RiderWorktrees.ContextMenu">
            <reference ref="RiderWorktrees.Open"/>
            <reference ref="RiderWorktrees.Create"/>
            <reference ref="RiderWorktrees.Remove"/>
            <separator/>
            <reference ref="RiderWorktrees.Lock"/>
            <reference ref="RiderWorktrees.Unlock"/>
        </group>

        <group id="RiderWorktrees.GitMenu"
               text="Worktrees"
               popup="true"
               icon="AllIcons.Vcs.Branch">
            <reference ref="RiderWorktrees.Create"/>
            <reference ref="RiderWorktrees.Open"/>
            <reference ref="RiderWorktrees.Remove"/>
            <separator/>
            <reference ref="RiderWorktrees.Refresh"/>
            <reference ref="RiderWorktrees.Prune"/>
            <separator/>
            <group id="RiderWorktrees.SwitchGroup"
                   class="com.github.tdavtyan.riderworktrees.actions.SwitchWorktreeActionGroup"
                   text="Switch to Worktree"
                   popup="true"/>
            <add-to-group group-id="GitRepositoryActions" anchor="last"/>
        </group>
    </actions>
</idea-plugin>
